  <div class="admin-main">
    <div class="admin-panel active" id="panel-dashboard">
      <div class="admin-title">Dashboard</div>
      <div class="admin-desc">Server overview and statistics</div>
      <div class="stats-grid">
        <div class="stat-card"><div class="stat-val" id="stat-users">0</div><div class="stat-label">Members</div></div>
        <div class="stat-card"><div class="stat-val" id="stat-online">0</div><div class="stat-label">Online</div></div>
