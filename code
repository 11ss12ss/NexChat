<script>
var COLORS = ['#5865f2','#57f287','#fee75c','#eb459e','#ed4245','#f0b232','#e67e22','#1abc9c','#e91e63','#9b59b6'];

var db = {
  users: {},
  messages: [],
  logs: [],
  nextId: 1,
  onlineUsers: new Set(),
  roles: [
    { name:'Admin', color:'#ed4245', permissions:['admin','manage_messages','kick','ban'], system:true },
    { name:'Moderator', color:'#57f287', permissions:['manage_messages','kick'], system:false },
    { name:'Member', color:'#b5bac1', permissions:[], system:true },
  ],
  serverName: 'NexChat',
  serverDesc: 'A real-time messaging platform',
  automod: { profanityEnabled:true, muteThreshold:3, customWords:[] },
  announcements: [],
};

var PROFANITY = [
  'fuck','shit','ass','bitch','cunt','dick','piss','cock','bastard','damn','hell',
  'crap','slut','whore','faggot','retard','idiot','moron','asshole',
  'motherfucker','bullshit'
];

var ROOMS = {
  general: 'The main hub. Keep it friendly!',
  offtopic: 'Anything goes. Almost.',
  gaming: 'Talk games, strategies & reviews.',
  tech: 'Dev talk, tools, and tech news.'
};

var session = { user: null, isAdmin: false };
var currentRoom = 'general';
var msgInterval = null;
var membersVisible = true;

function showView(id) {
  document.querySelectorAll('.view').forEach(function(v) { v.classList.remove('active'); });
  document.getElementById(id).classList.add('active');
}
function gotoAuth() { showView('auth-view'); }
function gotoAdminAuth() { showView('admin-auth-view'); resetAdminSteps(); }

function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach(function(b,i) { b.classList.toggle('active', (tab==='login'?i===0:i===1)); });
  document.getElementById('login-form').style.display = tab==='login'?'block':'none';
  document.getElementById('signup-form').style.display = tab==='signup'?'block':'none';
  var toggle = document.getElementById('auth-toggle-text');
  if (tab==='login') {
    toggle.innerHTML = "Need an account? <a onclick=\"switchTab('signup')\">Register</a>";
  } else {
    toggle.innerHTML = "Already have an account? <a onclick=\"switchTab('login')\">Log In</a>";
  }
  clearAuthError();
}

function showAuthError(msg) {
  var el = document.getElementById('auth-error');
  el.textContent = msg; el.style.display = 'block';
}
function clearAuthError() { document.getElementById('auth-error').style.display = 'none'; }

function doLogin() {
  var user = document.getElementById('login-user').value.trim().toLowerCase();
  var pass = document.getElementById('login-pass').value;
  if (!user || !pass) return showAuthError('Please fill in all fields.');
  var u = db.users[user];
  if (!u || u.password !== pass) return showAuthError('Login or password is invalid.');
  if (u.isBanned) return showAuthError('Your account has been disabled. Contact a server admin.');
  enterChat(user);
}

function doSignup() {
  var user = document.getElementById('signup-user').value.trim().toLowerCase();
  var pass = document.getElementById('signup-pass').value;
  var pass2 = document.getElementById('signup-pass2').value;
  if (!user || !pass || !pass2) return showAuthError('Please fill in all fields.');
  if (user.length < 3) return showAuthError('Username must be at least 3 characters.');
  if (!/^[a-z0-9_]+$/.test(user)) return showAuthError('Username can only contain lowercase letters, numbers, and underscores.');
  if (db.users[user]) return showAuthError('Username is already taken.');
  if (pass.length < 6) return showAuthError('Password must be at least 6 characters.');
  if (pass !== pass2) return showAuthError("Passwords don't match.");
  var color = COLORS[Object.keys(db.users).length % COLORS.length];
  db.users[user] = { password:pass, role:'member', warnings:0, isBanned:false, isMuted:false, joinDate:new Date().toISOString().split('T')[0], color:color };
  addLog('system', null, user, 'Account created');
  enterChat(user);
}

function enterChat(username) {
  session.user = username;
  session.isAdmin = false;
  db.onlineUsers.add(username);
  setupChatUI();
  showView('chat-view');
  switchRoom('general');
}

function logout() {
  if (session.user) db.onlineUsers.delete(session.user);
  session = { user: null, isAdmin: false };
  if (msgInterval) { clearInterval(msgInterval); msgInterval = null; }
  clearAuthError();
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
  showView('auth-view');
}

var adminStepNum = 1;
var adminAuthData = {};

function resetAdminSteps() {
  adminStepNum = 1; adminAuthData = {};
  for(var i=1;i<=3;i++) {
    document.getElementById('admin-step-'+i).classList.toggle('active', i===1);
    document.getElementById('step-ind-'+i).className = 'sec-step' + (i===1?' active':'');
    var err = document.getElementById('admin-err-'+i);
    if(err) { err.style.display='none'; err.textContent=''; }
  }
  ['admin-key','admin-user','admin-pass','admin-code'].forEach(function(id) {
    var el = document.getElementById(id); if(el) el.value='';
  });
}

function adminShowErr(step, msg) {
  var el = document.getElementById('admin-err-'+step);
  el.textContent = msg; el.style.display = 'block';
}

function advanceStep(to) {
  document.getElementById('admin-step-'+adminStepNum).classList.remove('active');
  document.getElementById('step-ind-'+adminStepNum).className = 'sec-step done';
  adminStepNum = to;
  document.getElementById('admin-step-'+to).classList.add('active');
  document.getElementById('step-ind-'+to).className = 'sec-step active';
}

function adminStep1() {
  var key = document.getElementById('admin-key').value.trim();
  if (key !== 'NEXCHAT-ADMIN') return adminShowErr(1, 'Invalid authorization key.');
  adminAuthData.key = key;
  advanceStep(2);
}

function adminStep2() {
  var user = document.getElementById('admin-user').value.trim();
  var pass = document.getElementById('admin-pass').value;
  var u = db.users[user];
  if (!u || u.role !== 'admin' || u.password !== pass) return adminShowErr(2, 'Invalid admin credentials.');
  adminAuthData.user = user;
  advanceStep(3);
}

function adminStep3() {
  var code = document.getElementById('admin-code').value.trim();
  if (code !== '847291') return adminShowErr(3, 'Invalid verification code.');
  session.user = adminAuthData.user;
  session.isAdmin = true;
  db.onlineUsers.add(adminAuthData.user);
  addLog('admin', adminAuthData.user, null, 'Admin login');
  showAdminPanel();
}

function setupChatUI() {
  var u = db.users[session.user];
  var el = document.getElementById('sidebar-avatar');
  el.style.background = u.color;
  el.style.color = '#fff';
  el.innerHTML = session.user[0].toUpperCase() + '<div class="online-dot"></div>';
  document.getElementById('sidebar-username').textContent = session.user;
  document.getElementById('sidebar-role').textContent = u.role === 'admin' ? 'Admin' : 'Online';
  renderMemberList();
  if (msgInterval) clearInterval(msgInterval);
  msgInterval = setInterval(function() {
    renderMessages();
    renderMemberList();
    updateInputState();
  }, 2000);
}

function toggleMembers() {
  membersVisible = !membersVisible;
  document.getElementById('member-list').style.display = membersVisible ? 'block' : 'none';
}

function switchRoom(room) {
  currentRoom = room;
  document.querySelectorAll('.room-btn').forEach(function(b) { b.classList.remove('active'); });
  var roomBtn = document.getElementById('room-'+room);
  if (roomBtn) roomBtn.classList.add('active');
  document.getElementById('chat-room-name').textContent = room === 'offtopic' ? 'off-topic' : room;
  document.getElementById('chat-room-desc').textContent = ROOMS[room] || '';
  document.getElementById('msg-input').placeholder = 'Message #' + (room === 'offtopic' ? 'off-topic' : room);
  renderMessages();
}

function renderMessages() {
  var area = document.getElementById('messages-area');
  var msgs = db.messages.filter(function(m) { return m.room === currentRoom && !m.deleted; });
  var html = '';
  var lastDate = '';
  var lastUser = '';
  var lastTs = 0;
  var roomDisplay = currentRoom === 'offtopic' ? 'off-topic' : currentRoom;
  html += '<div class="welcome-msg"><h2>Welcome to #' + roomDisplay + '!</h2><p>This is the start of the #' + roomDisplay + ' channel. ' + (ROOMS[currentRoom] || '') + '</p></div>';
  msgs.forEach(function(m) {
    var d = new Date(m.ts);
    var dateStr = d.toLocaleDateString('en-US', {month:'long', day:'numeric', year:'numeric'});
    if (dateStr !== lastDate) {
      html += '<div class="date-divider"><span>' + dateStr + '</span></div>';
      lastDate = dateStr;
      lastUser = '';
    }
    var u = db.users[m.username] || { color:'#888', role:'member' };
    var timeFull = d.toLocaleString('en-US', {month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit'});
    var timeShort = d.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
    var sameUser = m.username === lastUser && (m.ts - lastTs < 420000);
    var badge = u.role === 'admin' ? '<span class="msg-badge badge-admin">ADMIN</span>' : '';
    var flagNote = m.flagged ? '<div class="msg-flag">Message contained filtered content</div>' : '';
    if (sameUser) {
      html += '<div class="msg" id="msg-' + m.id + '"><div class="msg-avatar hidden-avatar"></div><div class="msg-content"><span class="msg-time inline-time">' + timeShort + '</span><div class="msg-text' + (m.flagged ? ' flagged' : '') + '">' + escHtml(m.text) + '</div>' + flagNote + '</div></div>';
    } else {
      html += '<div class="msg has-header" id="msg-' + m.id + '"><div class="msg-avatar" style="background:' + u.color + ';color:#fff">' + m.username[0].toUpperCase() + '</div><div class="msg-content"><div class="msg-header"><span class="msg-author" style="color:' + u.color + '">' + m.username + '</span>' + badge + '<span class="msg-time">' + timeFull + '</span></div><div class="msg-text' + (m.flagged ? ' flagged' : '') + '">' + escHtml(m.text) + '</div>' + flagNote + '</div></div>';
    }
    lastUser = m.username;
    lastTs = m.ts;
  });
  if (!msgs.length) {
    html += '<div class="empty-state"><div class="empty-icon">&#x1F4AD;</div><div>No messages yet. Start the conversation!</div></div>';
  }
  var wasBottom = area.scrollHeight - area.scrollTop - area.clientHeight < 80;
  area.innerHTML = html;
  if (wasBottom) area.scrollTop = area.scrollHeight;
}

function renderMemberList() {
  var content = document.getElementById('member-list-content');
  var onlineArr = Array.from(db.onlineUsers);
  var allUsers = Object.keys(db.users).filter(function(u) { return u !== 'superadmin'; });
  var offlineArr = allUsers.filter(function(u) { return !db.onlineUsers.has(u); });
  var html = '';
  if (onlineArr.length) {
    html += '<div class="member-group-title">Online \u2014 ' + onlineArr.length + '</div>';
    onlineArr.forEach(function(u) {
      var user = db.users[u]; if (!user) return;
      html += '<div class="member-item"><div class="m-avatar" style="background:' + user.color + ';color:#fff">' + u[0].toUpperCase() + '<div class="m-status online"></div></div><span class="m-name">' + u + '</span></div>';
    });
  }
  if (offlineArr.length) {
    html += '<div class="member-group-title">Offline \u2014 ' + offlineArr.length + '</div>';
    offlineArr.forEach(function(u) {
      var user = db.users[u]; if (!user) return;
      html += '<div class="member-item"><div class="m-avatar" style="background:' + user.color + ';color:#fff;opacity:0.4">' + u[0].toUpperCase() + '<div class="m-status offline"></div></div><span class="m-name" style="opacity:0.4">' + u + '</span></div>';
    });
  }
  content.innerHTML = html;
}

function updateInputState() {
  var u = db.users[session.user];
  var mutedBanner = document.getElementById('muted-banner');
  var warnBanner = document.getElementById('warning-banner');
  var input = document.getElementById('msg-input');
  if (!u) return;
  if (u.isBanned) { logout(); return; }
  mutedBanner.style.display = u.isMuted ? 'flex' : 'none';
  input.disabled = u.isMuted;
  if (!u.isMuted && u.warnings > 0) {
    var msgs = ['','First warning: Please be respectful in chat.','Final warning: Next violation will result in a mute.','You have been automatically muted.'];
    var w = Math.min(u.warnings, 3);
    document.getElementById('warning-text').textContent = msgs[w];
    warnBanner.style.display = w > 0 ? 'flex' : 'none';
  } else if (!u.isMuted) {
    warnBanner.style.display = 'none';
  }
}

function handleKey(e) { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); } }

function filterText(text) {
  if (!db.automod.profanityEnabled) return { filtered: text, wasFlagged: false };
  var filtered = text;
  var wasFlagged = false;
  var lower = text.toLowerCase();
  var allWords = PROFANITY.concat(db.automod.customWords);
  for (var i = 0; i < allWords.length; i++) {
    var word = allWords[i];
    if (!word) continue;
    var escaped = word.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    var re = new RegExp('\\b' + escaped + '\\b', 'gi');
    if (re.test(lower)) {
      wasFlagged = true;
      filtered = filtered.replace(new RegExp('\\b' + escaped + '\\b', 'gi'), function(m) { return '\u2588'.repeat(m.length); });
    }
  }
  return { filtered: filtered, wasFlagged: wasFlagged };
}

function sendMessage() {
  var input = document.getElementById('msg-input');
  var raw = input.value.trim();
  if (!raw) return;
  var u = db.users[session.user];
  if (!u || u.isMuted || u.isBanned) return;
  var result = filterText(raw);
  if (result.wasFlagged) {
    u.warnings++;
    var threshold = db.automod.muteThreshold;
    if (u.warnings >= threshold) {
      u.isMuted = true;
      addLog('auto', 'AutoMod', session.user, 'Auto-muted after ' + threshold + ' violations');
      notify('You have been automatically muted for repeated violations.', 'error', 6000);
    } else {
      addLog('auto', 'AutoMod', session.user, 'Warning issued (' + u.warnings + '/' + (threshold-1) + ')');
      notify('Warning ' + u.warnings + '/' + (threshold-1) + ': Your message contained filtered content.', 'warn', 5000);
    }
    updateInputState();
  }
  db.messages.push({ id: db.nextId++, username: session.user, room: currentRoom, text: result.filtered, ts: Date.now(), deleted: false, flagged: result.wasFlagged });
  input.value = '';
  renderMessages();
}

function showAdminPanel() { showView('admin-view'); adminTab('dashboard'); }
function exitAdmin() { if (session.isAdmin) enterChat(session.user); }

function adminTab(tab) {
  document.querySelectorAll('.admin-nav-btn').forEach(function(b) { b.classList.remove('active'); });
  document.querySelectorAll('.admin-panel').forEach(function(p) { p.classList.remove('active'); });
  if (event && event.currentTarget) event.currentTarget.classList.add('active');
  var panel = document.getElementById('panel-' + tab);
  if (panel) panel.classList.add('active');
  if (tab==='dashboard') renderDashboard();
  if (tab==='users') renderUsersTable();
  if (tab==='messages') renderMessagesTable();
  if (tab==='logs') renderLogs();
  if (tab==='roles') renderRoles();
  if (tab==='channels') renderChannels();
  if (tab==='announcements') renderAnnouncements();
}

function renderDashboard() {
  document.getElementById('stat-users').textContent = Object.keys(db.users).length;
  document.getElementById('stat-online').textContent = db.onlineUsers.size;
  document.getElementById('stat-messages').textContent = db.messages.filter(function(m){return !m.deleted;}).length;
  document.getElementById('stat-flagged').textContent = db.messages.filter(function(m){return m.flagged && !m.deleted;}).length;
  var logs = db.logs.slice(-5).reverse();
  document.getElementById('dash-logs').innerHTML = logs.length ? logs.map(logHTML).join('') : '<div class="empty-state" style="padding:20px"><div class="empty-icon">&#x1F4CB;</div><div>No recent activity</div></div>';
}

function logHTML(l) {
  var icons = { admin:'\u26A1', ban:'\uD83D\uDEAB', unban:'\u2705', warn:'\u26A0\uFE0F', mute:'\uD83D\uDD07', unmute:'\uD83D\uDD0A', 'delete':'\uD83D\uDDD1\uFE0F', auto:'\uD83E\uDD16', system:'\u2699\uFE0F', announce:'\uD83D\uDCE2' };
  var icon = icons[l.type] || '\u2699\uFE0F';
  var time = new Date(l.ts).toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  return '<div class="log-entry"><div class="log-icon" style="background:var(--surface3)">' + icon + '</div><div><div class="log-time">' + time + '</div><div class="log-text"><strong>' + (l.by || 'System') + '</strong> \u2014 ' + l.action + (l.target ? ' on <strong>' + l.target + '</strong>' : '') + '</div></div></div>';
}

function renderUsersTable() {
  var rows = Object.entries(db.users).filter(function(e) { return e[0] !== 'superadmin'; }).map(function(e) {
    var uname = e[0], u = e[1];
    var msgCount = db.messages.filter(function(m){return m.username===uname && !m.deleted;}).length;
    var status = u.isBanned ? '<span class="status-badge status-banned">Banned</span>' :
                 u.isMuted  ? '<span class="status-badge status-muted">Muted</span>' :
                 u.warnings >= 2 ? '<span class="status-badge status-warned">Warned</span>' :
                 '<span class="status-badge status-ok">Active</span>';
    var banBtn = u.isBanned
      ? "<button class=\"act-btn act-unban\" onclick=\"adminAction('unban','" + uname + "')\">Unban</button>"
      : "<button class=\"act-btn act-ban\" onclick=\"adminAction('ban','" + uname + "')\">Ban</button>";
    var muteBtn = u.isMuted
      ? "<button class=\"act-btn act-unban\" onclick=\"adminAction('unmute','" + uname + "')\">Unmute</button>"
      : "<button class=\"act-btn act-mute\" onclick=\"adminAction('mute','" + uname + "')\">Mute</button>";
    return '<tr><td><div style="display:flex;align-items:center;gap:8px"><div style="width:24px;height:24px;border-radius:50%;background:' + u.color + ';display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff">' + uname[0].toUpperCase() + '</div>' + uname + '</div></td><td>' + status + '</td><td><span style="color:' + (u.warnings>0?'var(--yellow)':'var(--text2)') + '">' + u.warnings + "</span></td><td>" + msgCount + "</td><td>" + u.joinDate + "</td><td><div class=\"action-btns\"><button class=\"act-btn act-warn\" onclick=\"adminAction('warn','" + uname + "')\">Warn</button>" + muteBtn + banBtn + '</div></td></tr>';
  });
  document.getElementById('users-table').innerHTML = rows.join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:30px">No members yet</td></tr>';
}

function renderMessagesTable() {
  var msgs = db.messages.slice().reverse().slice(0, 50);
  var rows = msgs.map(function(m) {
    var time = new Date(m.ts).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
    var flag = m.flagged ? '<span style="color:var(--yellow)">Flagged</span>' : '\u2014';
    var text = m.deleted ? '<em style="color:var(--text3)">Deleted</em>' : escHtml(m.text).slice(0,60) + (m.text.length>60?'\u2026':'');
    var delBtn = m.deleted ? '' : '<button class="act-btn act-del" onclick="adminDeleteMsg(' + m.id + ')">Delete</button>';
    var u = db.users[m.username];
    var color = u ? u.color : '#888';
    return '<tr><td><span style="color:' + color + '">' + m.username + '</span></td><td>#' + m.room + '</td><td style="max-width:250px">' + text + '</td><td>' + time + '</td><td>' + flag + '</td><td>' + delBtn + '</td></tr>';
  });
  document.getElementById('messages-table').innerHTML = rows.join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:30px">No messages</td></tr>';
}

function renderLogs() {
  var logs = db.logs.slice().reverse();
  document.getElementById('activity-logs').innerHTML = logs.length ? logs.map(logHTML).join('') : '<div class="empty-state"><div class="empty-icon">&#x1F4CB;</div><div>No activity recorded</div></div>';
}

function renderRoles() {
  var html = '';
  db.roles.forEach(function(r, i) {
    var permsText = r.permissions.length ? r.permissions.join(', ') : 'No special permissions';
    var delBtn = r.system ? '' : '<button class="act-btn act-del" onclick="deleteRole(' + i + ')">Delete</button>';
    html += '<div class="admin-card"><div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;"><span class="role-tag" style="background:' + r.color + '22;color:' + r.color + '">\u25CF ' + r.name + '</span>' + (r.system ? '<span style="font-size:12px;color:var(--text3)">System role</span>' : '') + '</div><div style="font-size:13px;color:var(--text-muted);margin-bottom:8px;">Permissions: ' + permsText + '</div>' + delBtn + '</div>';
  });
  document.getElementById('roles-list').innerHTML = html;
}

function createRole() {
  var name = document.getElementById('new-role-name').value.trim();
  var color = document.getElementById('new-role-color').value.trim() || '#b5bac1';
  if (!name) return notify('Please enter a role name.', 'error');
  if (db.roles.find(function(r) { return r.name.toLowerCase() === name.toLowerCase(); })) return notify('A role with that name already exists.', 'error');
  var permissions = [];
  if (document.getElementById('role-perm-manage').checked) permissions.push('manage_messages');
  if (document.getElementById('role-perm-kick').checked) permissions.push('kick');
  if (document.getElementById('role-perm-ban').checked) permissions.push('ban');
  if (document.getElementById('role-perm-admin').checked) permissions.push('admin');
  db.roles.push({ name:name, color:color, permissions:permissions, system:false });
  addLog('admin', session.user, null, 'Created role "' + name + '"');
  document.getElementById('new-role-name').value = '';
  document.getElementById('new-role-color').value = '';
  ['role-perm-manage','role-perm-kick','role-perm-ban','role-perm-admin'].forEach(function(id) { document.getElementById(id).checked = false; });
  renderRoles();
  notify('Role "' + name + '" created!', 'success');
}

function deleteRole(idx) {
  var role = db.roles[idx];
  if (!role || role.system) return;
  openModal('Delete Role', 'Delete the role <strong>' + role.name + '</strong>? This cannot be undone.', function() {
    addLog('admin', session.user, null, 'Deleted role "' + role.name + '"');
    db.roles.splice(idx, 1);
    renderRoles();
    notify('Role deleted.', 'info');
  });
}

function renderChannels() {
  var html = '';
  Object.entries(ROOMS).forEach(function(e) {
    var id = e[0], desc = e[1];
    var msgCount = db.messages.filter(function(m) { return m.room === id && !m.deleted; }).length;
    html += '<div class="admin-card" style="display:flex;align-items:center;gap:12px;"><span style="font-size:20px;color:var(--text3)">#</span><div style="flex:1"><div style="font-size:14px;font-weight:600;color:var(--text)">' + (id === 'offtopic' ? 'off-topic' : id) + '</div><div style="font-size:13px;color:var(--text-muted)">' + desc + '</div></div><span style="font-size:12px;color:var(--text3)">' + msgCount + " messages</span><button class=\"act-btn act-del\" onclick=\"deleteChannel('" + id + "')\">Delete</button></div>";
  });
  document.getElementById('channels-list').innerHTML = html;
}

function createChannel() {
  var name = document.getElementById('new-channel-name').value.trim().toLowerCase().replace(/\s+/g,'-').replace(/[^a-z0-9\-_]/g,'');
  var topic = document.getElementById('new-channel-topic').value.trim() || 'No topic set';
  if (!name) return notify('Please enter a channel name.', 'error');
  if (name.length < 2) return notify('Channel name must be at least 2 characters.', 'error');
  if (ROOMS[name]) return notify('A channel with that name already exists.', 'error');
  ROOMS[name] = topic;
  var roomsSection = document.querySelector('.rooms-section');
  var btn = document.createElement('button');
  btn.className = 'room-btn';
  btn.id = 'room-' + name;
  btn.onclick = function() { switchRoom(name); };
  btn.innerHTML = '<span class="room-hash">#</span> ' + name;
  roomsSection.appendChild(btn);
  addLog('admin', session.user, null, 'Created channel #' + name);
  document.getElementById('new-channel-name').value = '';
  document.getElementById('new-channel-topic').value = '';
  renderChannels();
  notify('Channel #' + name + ' created!', 'success');
}

function deleteChannel(id) {
  if (id === 'general') return notify('Cannot delete the #general channel.', 'error');
  openModal('Delete Channel', 'Delete <strong>#' + id + '</strong> and all its messages? This cannot be undone.', function() {
    delete ROOMS[id];
    db.messages = db.messages.filter(function(m) { return m.room !== id; });
    var btn = document.getElementById('room-' + id);
    if (btn) btn.remove();
    if (currentRoom === id) switchRoom('general');
    addLog('admin', session.user, null, 'Deleted channel #' + id);
    renderChannels();
    notify('Channel #' + id + ' deleted.', 'info');
  });
}

function renderAnnouncements() {
  document.getElementById('announce-channel').innerHTML = Object.keys(ROOMS).map(function(r) { return '<option value="' + r + '">' + (r === 'offtopic' ? 'off-topic' : r) + '</option>'; }).join('');
  var items = db.announcements.slice().reverse();
  document.getElementById('announcements-log').innerHTML = items.length ? items.map(function(a) {
    var time = new Date(a.ts).toLocaleString('en-US', {month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'});
    return '<div class="log-entry"><div class="log-icon" style="background:var(--surface3)">\uD83D\uDCE2</div><div><div class="log-time">' + time + '</div><div class="log-text"><strong>' + a.by + '</strong> in #' + a.channel + ': ' + escHtml(a.text) + '</div></div></div>';
  }).join('') : '<div class="empty-state" style="padding:20px">No announcements yet</div>';
}

function sendAnnouncement() {
  var channel = document.getElementById('announce-channel').value;
  var text = document.getElementById('announce-text').value.trim();
  if (!text) return notify('Please enter an announcement message.', 'error');
  db.messages.push({ id: db.nextId++, username: session.user, room: channel, text: '\uD83D\uDCE2 ANNOUNCEMENT \u2014 ' + text, ts: Date.now(), deleted: false, flagged: false });
  db.announcements.push({ by: session.user, channel: channel, text: text, ts: Date.now() });
  addLog('announce', session.user, null, 'Announcement in #' + channel);
  document.getElementById('announce-text').value = '';
  renderAnnouncements();
  notify('Announcement sent to #' + channel + '!', 'success');
}

function saveServerSettings() {
  var name = document.getElementById('server-name-input').value.trim();
  var desc = document.getElementById('server-desc-input').value.trim();
  if (!name) return notify('Server name cannot be empty.', 'error');
  db.serverName = name;
  db.serverDesc = desc;
  document.querySelector('.sidebar-header').textContent = name;
  addLog('admin', session.user, null, 'Updated server settings');
  notify('Server settings saved!', 'success');
}

function toggleProfanityFilter() {
  db.automod.profanityEnabled = document.getElementById('profanity-toggle').checked;
  document.getElementById('profanity-status').textContent = db.automod.profanityEnabled ? 'Enabled' : 'Disabled';
  addLog('admin', session.user, null, 'Profanity filter ' + (db.automod.profanityEnabled ? 'enabled' : 'disabled'));
  notify('Profanity filter ' + (db.automod.profanityEnabled ? 'enabled' : 'disabled') + '.', 'info');
}

function saveAutoModSettings() {
  var threshold = parseInt(document.getElementById('automute-threshold').value) || 3;
  db.automod.muteThreshold = Math.max(1, Math.min(10, threshold));
  document.getElementById('automute-threshold').value = db.automod.muteThreshold;
  addLog('admin', session.user, null, 'Auto-mute threshold set to ' + db.automod.muteThreshold);
  notify('AutoMod settings saved!', 'success');
}

function saveCustomWords() {
  var text = document.getElementById('custom-words').value;
  db.automod.customWords = text.split('\n').map(function(w) { return w.trim().toLowerCase(); }).filter(Boolean);
  addLog('admin', session.user, null, 'Updated custom word filter (' + db.automod.customWords.length + ' words)');
  notify('Custom filter updated with ' + db.automod.customWords.length + ' word(s).', 'success');
}

function adminAction(action, username) {
  var u = db.users[username];
  if (!u) return;
  var titles = { warn:'Issue Warning', mute:'Mute Member', unmute:'Unmute Member', ban:'Ban Member', unban:'Unban Member' };
  var bodies = {
    warn:'Issue a warning to <strong>' + username + '</strong>? They currently have ' + u.warnings + ' warning(s).',
    mute:'Mute <strong>' + username + '</strong>? They will not be able to send messages.',
    unmute:'Unmute <strong>' + username + '</strong>?',
    ban:'Ban <strong>' + username + '</strong> from the server? They will be unable to log in.',
    unban:'Unban <strong>' + username + '</strong>? They will regain access.',
  };
  openModal(titles[action], bodies[action], function() {
    if (action==='warn')   u.warnings++;
    if (action==='mute')   u.isMuted = true;
    if (action==='unmute') u.isMuted = false;
    if (action==='ban')    { u.isBanned = true; db.onlineUsers.delete(username); }
    if (action==='unban')  u.isBanned = false;
    addLog(action, session.user, username, action.charAt(0).toUpperCase() + action.slice(1));
    renderUsersTable();
    notify(action.charAt(0).toUpperCase() + action.slice(1) + ' applied to ' + username, 'success');
  });
}

function adminDeleteMsg(id) {
  openModal('Delete Message', 'Delete this message? This cannot be undone.', function() {
    var m = db.messages.find(function(x){return x.id===id;});
    if (m) { m.deleted = true; m.text = '[Message deleted]'; }
    addLog('delete', session.user, null, 'Deleted message #' + id);
    renderMessagesTable();
    notify('Message deleted', 'info');
  });
}

function addLog(type, by, target, action) {
  db.logs.push({ type:type, by:by, target:target, action:action, ts: Date.now() });
  if (db.logs.length > 200) db.logs.shift();
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function notify(msg, type, duration) {
  type = type || 'info';
  duration = duration || 3500;
  var el = document.createElement('div');
  el.className = 'notif notif-' + type;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(function() { el.style.opacity='0'; el.style.transition='opacity 0.3s'; setTimeout(function(){el.remove();}, 300); }, duration);
}

var modalCallback = null;
function openModal(title, body, cb) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').innerHTML = body;
  document.getElementById('modal').classList.add('open');
  modalCallback = cb;
}
function closeModal() {
  document.getElementById('modal').classList.remove('open');
  modalCallback = null;
}
document.getElementById('modal-confirm').onclick = function() {
  if (modalCallback) modalCallback();
  closeModal();
};

document.addEventListener('keydown', function(e) { if (e.key==='Escape') closeModal(); });

['admin-key','admin-user','admin-pass','admin-code'].forEach(function(id) {
  var el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('keydown', function(e) {
    if (e.key !== 'Enter') return;
    if (id==='admin-key') adminStep1();
    else if (id==='admin-user'||id==='admin-pass') adminStep2();
    else if (id==='admin-code') adminStep3();
  });
});

['login-user','login-pass'].forEach(function(id) {
  document.getElementById(id).addEventListener('keydown', function(e) { if(e.key==='Enter') doLogin(); });
});

