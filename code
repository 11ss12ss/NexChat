        <div style="display:flex;gap:16px;flex-wrap:wrap;margin-bottom:12px;">
          <label style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text2);cursor:pointer;"><input type="checkbox" id="role-perm-manage"> Manage Messages</label>
          <label style="display:flex;align-items:center;gap:8px;font-size:14px;color:var(--text2);cursor:pointer;"><input type="checkbox" id="role-perm-kick"> Kick Members</label>
