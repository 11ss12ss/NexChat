<script>
// ═══════════════════════════════════════════════════
// DATA STORE
// ═══════════════════════════════════════════════════
const COLORS = ['#f97316','#06b6d4','#8b5cf6','#ec4899','#10b981','#eab308','#ef4444','#3b82f6'];

const db = {
  users: {
    'alice': { password:'alice123', role:'member', warnings:0, isBanned:false, isMuted:false, joinDate:'2024-11-10', color:'#06b6d4' },
    'bob':   { password:'bob123',   role:'member', warnings:1, isBanned:false, isMuted:false, joinDate:'2024-12-02', color:'#8b5cf6' },
    'carol': { password:'carol123', role:'member', warnings:0, isBanned:false, isMuted:false, joinDate:'2025-01-15', color:'#10b981' },
    'dave':  { password:'dave123',  role:'member', warnings:2, isBanned:false, isMuted:true,  joinDate:'2025-02-08', color:'#f97316' },
    'superadmin': { password:'Nx@2024!', role:'admin', warnings:0, isBanned:false, isMuted:false, joinDate:'2024-01-01', color:'#ff6b35' },
  },
  messages: [
    { id:1, username:'alice',  room:'general', text:'Hey everyone! Welcome to NexChat 🎉', ts: Date.now()-3600000*5, deleted:false, flagged:false },
    { id:2, username:'bob',    room:'general', text:'Thanks! This place looks awesome.', ts: Date.now()-3600000*4, deleted:false, flagged:false },
    { id:3, username:'carol',  room:'general', text:'Loving the dark theme 🔥', ts: Date.now()-3600000*3, deleted:false, flagged:false },
    { id:4, username:'alice',  room:'general', text:'@bob have you checked out the #gaming channel yet?', ts: Date.now()-3600000*2, deleted:false, flagged:false },
    { id:5, username:'bob',    room:'gaming',  text:'Anyone playing anything good lately?', ts: Date.now()-3600000*2, deleted:false, flagged:false },
    { id:6, username:'carol',  room:'gaming',  text:'Just finished Elden Ring again. 100% recommend.', ts: Date.now()-3600000, deleted:false, flagged:false },
    { id:7, username:'alice',  room:'tech',    text:'What do you all think of the new AI models coming out?', ts: Date.now()-1800000, deleted:false, flagged:false },
    { id:8, username:'bob',    room:'tech',    text:'The progress is insane. GPT-5 looks wild.', ts: Date.now()-900000, deleted:false, flagged:false },
  ],
  logs: [],
  nextId: 9,
  onlineUsers: new Set(),
};

const PROFANITY = [
  'fuck','shit','ass','bitch','cunt','dick','piss','cock','bastard','damn','hell',
  'crap','slut','whore','nigger','nigga','faggot','retard','idiot','moron','asshole',
  'motherfucker','bullshit'
];

const ROOMS = {
  general: 'The main hub. Keep it friendly!',
  offtopic: 'Anything goes. Almost.',
  gaming: 'Talk games, strategies & reviews.',
  tech: 'Dev talk, tools, and tech news.'
};

let session = { user: null, isAdmin: false };
let currentRoom = 'general';
let msgInterval = null;

// ═══════════════════════════════════════════════════
// VIEWS
// ═══════════════════════════════════════════════════
function showView(id) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function gotoAuth() { showView('auth-view'); }
function gotoAdminAuth() { showView('admin-auth-view'); resetAdminSteps(); }

// ═══════════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════════
function switchTab(tab) {
  document.querySelectorAll('.tab-btn').forEach((b,i) => b.classList.toggle('active', (tab==='login'?i===0:i===1)));
  document.getElementById('login-form').style.display = tab==='login'?'block':'none';
  document.getElementById('signup-form').style.display = tab==='signup'?'block':'none';
  clearAuthError();
}

function showAuthError(msg) {
  const el = document.getElementById('auth-error');
  el.textContent = msg; el.style.display = 'block';
}
function clearAuthError() {
  document.getElementById('auth-error').style.display = 'none';
}

function doLogin() {
  const user = document.getElementById('login-user').value.trim().toLowerCase();
  const pass = document.getElementById('login-pass').value;
  if (!user || !pass) return showAuthError('Please fill in all fields.');
  const u = db.users[user];
  if (!u || u.password !== pass) return showAuthError('Invalid username or password.');
  if (u.isBanned) return showAuthError('Your account has been banned. Contact an administrator.');
  enterChat(user);
}

function doSignup() {
  const user = document.getElementById('signup-user').value.trim().toLowerCase();
  const pass = document.getElementById('signup-pass').value;
  const pass2 = document.getElementById('signup-pass2').value;
  if (!user || !pass || !pass2) return showAuthError('Please fill in all fields.');
  if (user.length < 3) return showAuthError('Username must be at least 3 characters.');
  if (!/^[a-z0-9_]+$/.test(user)) return showAuthError('Username can only contain letters, numbers, and underscores.');
  if (db.users[user]) return showAuthError('That username is already taken.');
  if (pass.length < 6) return showAuthError('Password must be at least 6 characters.');
  if (pass !== pass2) return showAuthError('Passwords do not match.');
  const color = COLORS[Object.keys(db.users).length % COLORS.length];
  db.users[user] = { password:pass, role:'member', warnings:0, isBanned:false, isMuted:false, joinDate:new Date().toISOString().split('T')[0], color };
  addLog('system', null, user, 'User registered');
  enterChat(user);
}

function enterChat(username) {
  session.user = username;
  session.isAdmin = false;
  db.onlineUsers.add(username);
  setupChatUI();
  showView('chat-view');
  switchRoom('general');
}

function logout() {
  if (session.user) db.onlineUsers.delete(session.user);
  session = { user: null, isAdmin: false };
  if (msgInterval) { clearInterval(msgInterval); msgInterval = null; }
  clearAuthError();
  document.getElementById('login-user').value = '';
  document.getElementById('login-pass').value = '';
  showView('auth-view');
}

// ═══════════════════════════════════════════════════
// ADMIN AUTH
// ═══════════════════════════════════════════════════
let adminStepNum = 1;
let adminAuthData = {};

function resetAdminSteps() {
  adminStepNum = 1;
  adminAuthData = {};
  for(let i=1;i<=3;i++) {
    document.getElementById(`admin-step-${i}`).classList.toggle('active', i===1);
    document.getElementById(`step-ind-${i}`).className = 'sec-step' + (i===1?' active':'');
    const err = document.getElementById(`admin-err-${i}`);
    if(err) { err.style.display='none'; err.textContent=''; }
  }
  ['admin-key','admin-user','admin-pass','admin-code'].forEach(id => {
    const el = document.getElementById(id); if(el) el.value='';
  });
}

function adminShowErr(step, msg) {
  const el = document.getElementById(`admin-err-${step}`);
  el.textContent = msg; el.style.display = 'block';
  el.style.animation = 'none'; el.offsetHeight;
  el.style.animation = '';
}

function advanceStep(to) {
  document.getElementById(`admin-step-${adminStepNum}`).classList.remove('active');
  document.getElementById(`step-ind-${adminStepNum}`).className = 'sec-step done';
  adminStepNum = to;
  document.getElementById(`admin-step-${to}`).classList.add('active');
  document.getElementById(`step-ind-${to}`).className = 'sec-step active';
}

function adminStep1() {
  const key = document.getElementById('admin-key').value.trim();
  if (key !== 'NEXCHAT-ADMIN') return adminShowErr(1, '⛔ Invalid authorization key.');
  adminAuthData.key = key;
  advanceStep(2);
}

function adminStep2() {
  const user = document.getElementById('admin-user').value.trim();
  const pass = document.getElementById('admin-pass').value;
  const u = db.users[user];
  if (!u || u.role !== 'admin' || u.password !== pass) return adminShowErr(2, '⛔ Invalid admin credentials.');
  adminAuthData.user = user;
  advanceStep(3);
}

function adminStep3() {
  const code = document.getElementById('admin-code').value.trim();
  if (code !== '847291') return adminShowErr(3, '⛔ Invalid verification code.');
  session.user = adminAuthData.user;
  session.isAdmin = true;
  db.onlineUsers.add(adminAuthData.user);
  addLog('admin', adminAuthData.user, null, 'Admin login');
  showAdminPanel();
}

// ═══════════════════════════════════════════════════
// CHAT UI
// ═══════════════════════════════════════════════════
function setupChatUI() {
  const u = db.users[session.user];
  const el = document.getElementById('sidebar-avatar');
  el.style.background = u.color;
  el.style.color = '#fff';
  el.innerHTML = session.user[0].toUpperCase() + '<div class="online-dot"></div>';
  document.getElementById('sidebar-username').textContent = session.user;
  document.getElementById('sidebar-role').textContent = u.role === 'admin' ? '⚡ Admin' : 'Member';
  renderOnlineList();
  if (msgInterval) clearInterval(msgInterval);
  msgInterval = setInterval(() => {
    renderMessages();
    renderOnlineList();
    updateInputState();
  }, 1000);
}

function switchRoom(room) {
  currentRoom = room;
  document.querySelectorAll('.room-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(`room-${room}`).classList.add('active');
  document.getElementById('chat-room-name').textContent = room;
  document.getElementById('chat-room-desc').textContent = ROOMS[room];
  document.getElementById('msg-input').placeholder = `Message #${room}...`;
  renderMessages();
}

function renderMessages() {
  const area = document.getElementById('messages-area');
  const msgs = db.messages.filter(m => m.room === currentRoom && !m.deleted);
  let html = '';
  let lastDate = '';
  msgs.forEach(m => {
    const d = new Date(m.ts);
    const dateStr = d.toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'});
    if (dateStr !== lastDate) {
      html += `<div class="date-divider"><span>${dateStr}</span></div>`;
      lastDate = dateStr;
    }
    const u = db.users[m.username] || { color:'#888', role:'member' };
    const timeStr = d.toLocaleTimeString('en-US', {hour:'2-digit', minute:'2-digit'});
    const badge = u.role==='admin' ? '<span class="msg-badge badge-admin">ADMIN</span>' : '';
    const flagNote = m.flagged ? '<div class="msg-flag">⚠ Message contained filtered content</div>' : '';
    html += `
      <div class="msg" id="msg-${m.id}">
        <div class="msg-avatar" style="background:${u.color};color:#fff">${m.username[0].toUpperCase()}</div>
        <div class="msg-content">
          <div class="msg-header">
            <span class="msg-author" style="color:${u.color}">${m.username}</span>
            ${badge}
            <span class="msg-time">${timeStr}</span>
          </div>
          <div class="msg-text${m.flagged?' flagged':''}">${escHtml(m.text)}</div>
          ${flagNote}
        </div>
      </div>`;
  });
  if (!msgs.length) html = '<div class="empty-state"><div class="empty-icon">💬</div><div>No messages yet. Say hello!</div></div>';
  const wasBottom = area.scrollHeight - area.scrollTop - area.clientHeight < 80;
  area.innerHTML = html;
  if (wasBottom) area.scrollTop = area.scrollHeight;
}

function renderOnlineList() {
  const list = document.getElementById('online-list');
  const onlineArr = [...db.onlineUsers].slice(0, 8);
  list.innerHTML = onlineArr.map(u => {
    const user = db.users[u];
    const color = user ? user.color : '#888';
    return `<div class="online-user"><div class="ava" style="background:${color};color:#fff">${u[0].toUpperCase()}</div><span class="oname">${u}</span><div class="online-dot2"></div></div>`;
  }).join('');
}

function updateInputState() {
  const u = db.users[session.user];
  const mutedBanner = document.getElementById('muted-banner');
  const warnBanner = document.getElementById('warning-banner');
  const input = document.getElementById('msg-input');
  const btn = document.getElementById('send-btn');
  if (!u) return;
  if (u.isBanned) { logout(); return; }
  const muted = u.isMuted;
  mutedBanner.style.display = muted ? 'flex' : 'none';
  input.disabled = muted;
  btn.disabled = muted;
  if (!muted && u.warnings > 0) {
    const msgs = [
      '',
      '⚠️ First warning: Watch your language. One more and you\'ll be muted.',
      '⚠️ Final warning: Next violation will result in a mute.',
      '⚠️ You have been automatically muted for repeated violations.',
    ];
    const w = Math.min(u.warnings, 3);
    document.getElementById('warning-text').textContent = msgs[w];
    warnBanner.style.display = w>0 ? 'flex' : 'none';
  } else if (!muted) {
    warnBanner.style.display = 'none';
  }
}

// ═══════════════════════════════════════════════════
// MESSAGING
// ═══════════════════════════════════════════════════
function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
}

function filterText(text) {
  let filtered = text;
  let wasFlagged = false;
  const lower = text.toLowerCase();
  for (const word of PROFANITY) {
    const re = new RegExp(`\\b${word}\\b`, 'gi');
    if (re.test(lower)) {
      wasFlagged = true;
      filtered = filtered.replace(re, m => '*'.repeat(m.length));
    }
  }
  return { filtered, wasFlagged };
}

function sendMessage() {
  const input = document.getElementById('msg-input');
  const raw = input.value.trim();
  if (!raw) return;
  const u = db.users[session.user];
  if (!u || u.isMuted || u.isBanned) return;

  const { filtered, wasFlagged } = filterText(raw);

  if (wasFlagged) {
    u.warnings++;
    if (u.warnings >= 3) {
      u.isMuted = true;
      addLog('auto', 'System', session.user, 'Auto-muted after 3 profanity violations');
      notify('🔇 You have been automatically muted for repeated profanity violations.', 'error', 6000);
    } else {
      addLog('auto', 'System', session.user, `Profanity warning issued (${u.warnings}/2)`);
      notify(`⚠️ Warning ${u.warnings}/2: Your message contained filtered content.`, 'warn', 5000);
    }
    updateInputState();
  }

  db.messages.push({
    id: db.nextId++,
    username: session.user,
    room: currentRoom,
    text: filtered,
    ts: Date.now(),
    deleted: false,
    flagged: wasFlagged,
  });

  input.value = '';
  renderMessages();
}

// ═══════════════════════════════════════════════════
// ADMIN PANEL
// ═══════════════════════════════════════════════════
function showAdminPanel() {
  showView('admin-view');
  adminTab('dashboard');
}

function exitAdmin() {
  if (session.isAdmin) {
    session.isAdmin = false;
    db.onlineUsers.delete(session.user);
    session.user = null;
    showView('auth-view');
    resetAdminSteps();
  }
}

function adminTab(tab) {
  document.querySelectorAll('.admin-nav-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.admin-panel').forEach(p => p.classList.remove('active'));
  event.currentTarget && event.currentTarget.classList.add('active');
  document.getElementById(`panel-${tab}`).classList.add('active');
  // highlight nav
  document.querySelectorAll('.admin-nav-btn').forEach(b => {
    if (b.textContent.toLowerCase().includes(tab.slice(0,4))) b.classList.add('active');
  });
  if (tab==='dashboard') renderDashboard();
  if (tab==='users') renderUsersTable();
  if (tab==='messages') renderMessagesTable();
  if (tab==='logs') renderLogs();
}

function renderDashboard() {
  const users = Object.keys(db.users);
  document.getElementById('stat-users').textContent = users.length;
  document.getElementById('stat-messages').textContent = db.messages.filter(m=>!m.deleted).length;
  document.getElementById('stat-flagged').textContent = db.messages.filter(m=>m.flagged&&!m.deleted).length;
  document.getElementById('stat-banned').textContent = users.filter(u=>db.users[u].isBanned).length;
  const logs = db.logs.slice(-5).reverse();
  document.getElementById('dash-logs').innerHTML = logs.length ? logs.map(l => logHTML(l)).join('') : '<div class="empty-state" style="padding:20px"><div class="empty-icon">📋</div><div>No recent activity</div></div>';
}

function logHTML(l) {
  const icons = { admin:'⚡', ban:'🚫', unban:'✅', warn:'⚠️', mute:'🔇', unmute:'🔊', delete:'🗑️', auto:'🤖', system:'⚙️' };
  const colors = { admin:'rgba(255,107,53,0.15)', ban:'rgba(248,81,73,0.12)', warn:'rgba(227,179,65,0.12)', delete:'rgba(248,81,73,0.12)', auto:'rgba(124,58,237,0.12)', system:'rgba(139,148,158,0.1)' };
  const color = colors[l.type] || colors.system;
  const icon = icons[l.type] || '⚙️';
  const time = new Date(l.ts).toLocaleTimeString('en-US', {hour:'2-digit',minute:'2-digit',second:'2-digit'});
  return `<div class="log-entry">
    <div class="log-icon" style="background:${color}">${icon}</div>
    <div>
      <div class="log-time">${time}</div>
      <div class="log-text"><strong>${l.by || 'System'}</strong> — ${l.action}${l.target?' on <strong>'+l.target+'</strong>':''}</div>
    </div>
  </div>`;
}

function renderUsersTable() {
  const rows = Object.entries(db.users).filter(([u]) => u !== 'superadmin').map(([uname, u]) => {
    const msgCount = db.messages.filter(m=>m.username===uname&&!m.deleted).length;
    const status = u.isBanned ? '<span class="status-badge status-banned">Banned</span>' :
                   u.isMuted  ? '<span class="status-badge status-muted">Muted</span>' :
                   u.warnings >= 2 ? '<span class="status-badge status-warned">Warned</span>' :
                   '<span class="status-badge status-ok">Active</span>';
    const banBtn = u.isBanned
      ? `<button class="act-btn act-unban" onclick="adminAction('unban','${uname}')">Unban</button>`
      : `<button class="act-btn act-ban" onclick="adminAction('ban','${uname}')">Ban</button>`;
    const muteBtn = u.isMuted
      ? `<button class="act-btn act-unban" onclick="adminAction('unmute','${uname}')">Unmute</button>`
      : `<button class="act-btn act-mute" onclick="adminAction('mute','${uname}')">Mute</button>`;
    return `<tr>
      <td><div style="display:flex;align-items:center;gap:8px"><div style="width:24px;height:24px;border-radius:50%;background:${u.color};display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:#fff">${uname[0].toUpperCase()}</div>${uname}</div></td>
      <td>${status}</td>
      <td><span style="color:${u.warnings>0?'var(--yellow)':'var(--text2)'}">${u.warnings}</span></td>
      <td>${msgCount}</td>
      <td>${u.joinDate}</td>
      <td><div class="action-btns">
        <button class="act-btn act-warn" onclick="adminAction('warn','${uname}')">Warn</button>
        ${muteBtn}${banBtn}
      </div></td>
    </tr>`;
  });
  document.getElementById('users-table').innerHTML = rows.join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:30px">No users found</td></tr>';
}

function renderMessagesTable() {
  const msgs = [...db.messages].reverse().slice(0, 50);
  const rows = msgs.map(m => {
    const time = new Date(m.ts).toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit'});
    const flag = m.flagged ? '<span style="color:var(--yellow)">⚠️ Profanity</span>' : '—';
    const text = m.deleted ? '<em style="color:var(--text3)">Deleted</em>' : escHtml(m.text).slice(0,60) + (m.text.length>60?'…':'');
    const delBtn = m.deleted ? '' : `<button class="act-btn act-del" onclick="adminDeleteMsg(${m.id})">Delete</button>`;
    const u = db.users[m.username];
    const color = u ? u.color : '#888';
    return `<tr>
      <td><span style="color:${color}">${m.username}</span></td>
      <td>#${m.room}</td>
      <td style="max-width:250px">${text}</td>
      <td>${time}</td>
      <td>${flag}</td>
      <td>${delBtn}</td>
    </tr>`;
  });
  document.getElementById('messages-table').innerHTML = rows.join('') || '<tr><td colspan="6" style="text-align:center;color:var(--text3);padding:30px">No messages</td></tr>';
}

function renderLogs() {
  const container = document.getElementById('activity-logs');
  const logs = [...db.logs].reverse();
  container.innerHTML = logs.length ? logs.map(l=>logHTML(l)).join('') : '<div class="empty-state"><div class="empty-icon">📋</div><div>No activity recorded</div></div>';
}

// Admin actions
function adminAction(action, username) {
  const u = db.users[username];
  if (!u) return;
  const titles = { warn:'Issue Warning', mute:'Mute User', unmute:'Unmute User', ban:'Ban User', unban:'Unban User' };
  const bodies = {
    warn:`Issue an official warning to <strong>${username}</strong>? They currently have ${u.warnings} warning(s).`,
    mute:`Mute <strong>${username}</strong>? They won't be able to send messages.`,
    unmute:`Unmute <strong>${username}</strong>?`,
    ban:`Permanently ban <strong>${username}</strong>? They will be unable to log in.`,
    unban:`Unban <strong>${username}</strong>? They will regain access to the platform.`,
  };
  openModal(titles[action], bodies[action], () => {
    if (action==='warn')   { u.warnings++; }
    if (action==='mute')   { u.isMuted = true; }
    if (action==='unmute') { u.isMuted = false; }
    if (action==='ban')    { u.isBanned = true; db.onlineUsers.delete(username); }
    if (action==='unban')  { u.isBanned = false; }
    addLog(action, 'superadmin', username, `Admin ${action}`);
    renderUsersTable();
    notify(`✅ Action "${action}" applied to ${username}`, 'success');
  });
}

function adminDeleteMsg(id) {
  openModal('Delete Message', 'Permanently delete this message? This cannot be undone.', () => {
    const m = db.messages.find(x=>x.id===id);
    if (m) { m.deleted = true; m.text = '[Deleted by admin]'; }
    addLog('delete', 'superadmin', null, `Deleted message #${id}`);
    renderMessagesTable();
    notify('🗑️ Message deleted', 'info');
  });
}

// ═══════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════
function addLog(type, by, target, action) {
  db.logs.push({ type, by, target, action, ts: Date.now() });
  if (db.logs.length > 200) db.logs.shift();
}

function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function notify(msg, type='info', duration=3500) {
  const el = document.createElement('div');
  el.className = `notif notif-${type}`;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => { el.style.opacity='0'; el.style.transition='opacity 0.3s'; setTimeout(()=>el.remove(), 300); }, duration);
}

let modalCallback = null;
function openModal(title, body, cb) {
  document.getElementById('modal-title').textContent = title;
  document.getElementById('modal-body').innerHTML = body;
  document.getElementById('modal').classList.add('open');
  modalCallback = cb;
}
function closeModal() {
  document.getElementById('modal').classList.remove('open');
  modalCallback = null;
}
document.getElementById('modal-confirm').onclick = () => {
  closeModal();
  if (modalCallback) modalCallback();
};

// ─── Keyboard shortcuts ───
document.addEventListener('keydown', e => {
  if (e.key==='Escape') closeModal();
});

// ─── Populate some demo online users ───
['alice','carol'].forEach(u => db.onlineUsers.add(u));

// ─── Admin nav click fix ───
document.querySelectorAll('.admin-nav-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.admin-nav-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
  });
});

// ─── Enter key on admin auth inputs ───
['admin-key','admin-user','admin-pass','admin-code'].forEach(id => {
  const el = document.getElementById(id);
  if (!el) return;
  el.addEventListener('keydown', e => {
    if (e.key !== 'Enter') return;
    if (id==='admin-key') adminStep1();
    else if (id==='admin-user'||id==='admin-pass') adminStep2();
    else if (id==='admin-code') adminStep3();
  });
});

['login-user','login-pass'].forEach(id => {
  document.getElementById(id).addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });
});
</script>
